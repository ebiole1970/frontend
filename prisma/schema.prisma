generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  role          String   @default("user")
  onboardingDone Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  reports       Report[]
  subscriptions Subscription[]
  tickets       HelpdeskTicket[]
  bookings      ConsultationBooking[]
}

model Company {
  id            String   @id @default(cuid())
  legalName     String
  vatNumber     String?  @unique
  annualRevenue Float?
  nis2Class     Nis2Class @default(ESSENTIAL)
  country       String   @default("IT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  assets        Asset[]
  scanRuns      ScanRun[]
}

model Asset {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  type          AssetType
  value         String
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScanRun {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  requestedById String?
  requestedBy   User?    @relation(fields: [requestedById], references: [id])
  scanType      String
  status        ScanStatus @default(QUEUED)
  startedAt     DateTime?
  finishedAt    DateTime?
  rawPayload    Json?
  maskedPayload Json?
  createdAt     DateTime @default(now())
}

model Report {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id])
  userId             String

  reportType         ReportType @default(STANDARD)
  domain             String
  cyberRiskScore     Int
  nis2ReadinessScore Int
  nis2SanctionCapEur Int     // calcolo (fatturato * 0.02) con minimo 10M€

  dnsFindings        Json
  osintFindings      Json
  infrastructureFindings Json
  nis2Radar          Json    // dati per grafico a ragnatela dei gap

  pdfUrl             String? // link al PDF generato da FastAPI
}

model Subscription {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  userId            String

  stripeCustomerId  String
  stripeSubscriptionId String?
  plan              PlanTier
  status            SubscriptionStatus
  currentPeriodEnd  DateTime?
  cancelledAt       DateTime?
}

model HelpdeskTicket {
  id            String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  subject        String
  message        String
  status         TicketStatus @default(OPEN)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ConsultationBooking {
  id            String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  provider       String   @default("Calendly")
  externalRef    String?
  meetingAt      DateTime?
  status         BookingStatus @default(PENDING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum Nis2Class {
  ESSENTIAL
  IMPORTANT
}

enum AssetType {
  DOMAIN
  EMAIL_DOMAIN
  PUBLIC_IP
  SUBDOMAIN
}

enum ScanStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum ReportType {
  STANDARD
  BOARD_PREMIUM
}

enum PlanTier {
  STARTER
  GROWTH
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum TicketStatus {
  OPEN
  IN_REVIEW
  ANSWERED
  CLOSED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

