# Copia in .env.local e compila. Mai committare .env.local.
# Porta come in start-frontend.ps1 (next dev -p 3001)
NEXTAUTH_URL=http://localhost:3001
AUTH_SECRET=genera_con_openssl_rand_base64_32
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Opzionale: URL backend solo per il server Next (login). Default = NEXT_PUBLIC_API_BASE_URL
# AUTH_BACKEND_URL=http://127.0.0.1:8000
# Cloudflare Turnstile (widget registrazione). In dev puoi omettere (backend senza secret non richiede token).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
